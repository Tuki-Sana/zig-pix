{
  "name": "zigpix",
  "version": "0.2.0",
  "description": "High-performance image processing engine (Zig + libavif). Decode, resize, WebP/AVIF encode. Speed vs Sharp depends on pipeline and hardware — see README benchmarks.",
  "type": "module",
  "main": "js/dist/index.js",
  "types": "js/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./js/dist/index.d.ts",
      "import": "./js/dist/index.js"
    },
    "./deno": "./js/dist/index.deno.js"
  },
  "files": [
    "js/dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES"
  ],
  "scripts": {
    "build": "tsc && npx esbuild js/src/index.deno.ts --bundle=false --platform=neutral --format=esm --outfile=js/dist/index.deno.js",
    "prepublishOnly": "npm run build",
    "test:bun": "bash test/ffi/run.sh",
    "test:node": "bash test/ffi/run.node.sh",
    "mem:peak": "bash scripts/mem-peak.sh",
    "bench": "tsx bench/bench.ts",
    "bench:quality": "tsx bench/bench-quality.ts",
    "bench:aggregate": "node scripts/bench-aggregate-multi-run.mjs"
  },
  "keywords": [
    "avif",
    "webp",
    "image",
    "resize",
    "zig",
    "native"
  ],
  "author": "月村つかさ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tuki-Sana/zig-pix.git"
  },
  "optionalDependencies": {
    "zigpix-darwin-arm64": "0.2.0",
    "zigpix-linux-x64": "0.2.0",
    "zigpix-win32-x64": "0.2.0"
  },
  "dependencies": {
    "koffi": "^2.16.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "sharp": "^0.34.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
