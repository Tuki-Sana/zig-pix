{
  "name": "zenpix",
  "version": "0.6.0",
  "description": "High-performance image processing engine (Zig + libavif). Decode, resize, WebP/AVIF encode. Speed vs Sharp depends on pipeline and hardware — see README benchmarks.",
  "type": "module",
  "main": "js/dist/index.js",
  "types": "js/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./js/dist/index.d.ts",
      "import": "./js/dist/index.js"
    },
    "./deno": "./js/dist/index.deno.js"
  },
  "bin": {
    "zenpix": "js/dist/cli.js"
  },
  "files": [
    "js/dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES"
  ],
  "scripts": {
    "build": "tsc && npx esbuild js/src/index.deno.ts --bundle=false --platform=neutral --format=esm --outfile=js/dist/index.deno.js && node scripts/add-shebang.mjs",
    "prepublishOnly": "npm run build",
    "test:bun": "bash test/ffi/run.sh",
    "test:node": "bash test/ffi/run.node.sh",
    "mem:peak": "bash scripts/mem-peak.sh",
    "bench": "tsx bench/bench.ts",
    "bench:threads": "tsx bench/bench-threads.ts",
    "bench:quality": "tsx bench/bench-quality.ts",
    "bench:aggregate": "node scripts/bench-aggregate-multi-run.mjs"
  },
  "keywords": [
    "avif",
    "webp",
    "image",
    "resize",
    "zig",
    "native"
  ],
  "author": "月村つかさ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tuki-Sana/zenpix.git"
  },
  "optionalDependencies": {
    "zenpix-darwin-arm64": "0.6.0",
    "zenpix-darwin-x64": "0.6.0",
    "zenpix-linux-x64": "0.6.0",
    "zenpix-win32-x64": "0.6.0"
  },
  "dependencies": {
    "koffi": "^2.16.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
