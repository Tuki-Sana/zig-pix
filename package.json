{
  "name": "zigpix",
  "version": "0.0.2",
  "description": "High-performance image processing engine (Zig + libavif). Faster AVIF encoding than Sharp.",
  "type": "module",
  "main": "js/dist/index.js",
  "types": "js/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./js/dist/index.d.ts",
      "import": "./js/dist/index.js"
    }
  },
  "files": [
    "js/dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test:bun": "bash test/ffi/run.sh",
    "test:node": "bash test/ffi/run.node.sh"
  },
  "keywords": [
    "avif",
    "webp",
    "image",
    "resize",
    "zig",
    "native"
  ],
  "author": "月村つかさ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tuki-Sana/zig-pix.git"
  },
  "optionalDependencies": {
    "zigpix-darwin-arm64": "0.0.2",
    "zigpix-linux-x64": "0.0.2"
  },
  "dependencies": {
    "koffi": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
